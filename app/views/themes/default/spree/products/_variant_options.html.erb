<%# app/views/themes/default/spree/products/_variant_options.html.erb %>
<% selected_option = product_selected_option_for_option(option_type, product: product, selected_variant: selected_variant, options_param_name: options_param_name) %>

<%# 1. 5.4-Compatible Availability Logic %>
<%# We eager load option_values and prices to prevent N+1 queries %>
<% variants = product.variants.includes(:option_values, :prices) %>
<% variants_available_arr = variants.map { |v| v.purchasable? && v.price_in(current_currency).amount.present? } %>

<%# 2. Map Option Value names by their Option Type IDs for accurate matching %>
<% option_type_ids = product.option_types.pluck(:id) %>
<% variant_ov_names = variants.map do |v| 
     option_type_ids.map { |id| v.option_values.find { |ov| ov.option_type_id == id }&.name }
   end %>

<% product_option_values_for_option(option_type, product: product).each_with_index do |value, index| %>
  <% option_disabled = true %>
  
  <%# 3. Validation Loop %>
  <% variant_ov_names.each_with_index do |names, idx| %>
    <% is_match = case position
       when 0
         names[0] == value.name
       when 1
         names[0] == product_selected_option_for_option(product.option_types[0], product: product, options_param_name: options_param_name)&.name &&
         names[1] == value.name
       when 2
         names[0] == product_selected_option_for_option(product.option_types[0], product: product, options_param_name: options_param_name)&.name &&
         names[1] == product_selected_option_for_option(product.option_types[1], product: product, options_param_name: options_param_name)&.name &&
         names[2] == value.name
       else
         false
       end %>

    <% if is_match && variants_available_arr[idx] %>
      <% option_disabled = false %>
      <% break %>
    <% end %>
  <% end %>

  <%# --- Rendering Logic --- %>
  <% if option_type.color_swatch? || (option_type.respond_to?(:kind) && option_type.kind == 'color_swatch') %>
    <li role="option" aria-label="<%= value.presentation %>">
      <label class="cursor-pointer" aria-label="<%= value.presentation %>">
        <%= radio_button_tag option_type.presentation, value.name, selected_option == value,
              id: "product-option-#{product.id}-#{position}-#{index}",
              class: "sr-only peer color-input",
              disabled: option_disabled,
              data: { action: 'change->product-form#updateVariant', product_form_target: 'option', option_id: option_type.id } %>
        <%= render 'spree/products/color_picker', disabled: option_disabled %>
      </label>
    </li>

  <% elsif option_type.respond_to?(:kind) && option_type.kind == 'buttons' %>
    <label for="product-option-<%= product.id %>-<%= position %>-<%= index %>" 
           class="<%= class_names(
             'inline-flex items-center justify-center w-max min-w-[48px] h-10 px-4 text-sm font-medium transition-all cursor-pointer rounded-button',
             {
               'btn-primary border-transparent': selected_option == value,
               'border border-default text-default bg-background hover:bg-accent': selected_option != value,
               'opacity-40 cursor-not-allowed': option_disabled
             }
           ) %>">
      <%= radio_button_tag option_type.presentation, value.name, selected_option == value,
            id: "product-option-#{product.id}-#{position}-#{index}",
            class: "sr-only",
            disabled: option_disabled,
            data: { action: 'change->product-form#updateVariant', product_form_target: 'option', option_id: option_type.id } %>
      <%= value.presentation %>
    </label>

  <% else %>
    <%= radio_button_tag option_type.presentation, value.name, selected_option == value,
          class: "sr-only",
          data: { action: 'change->product-form#updateVariant', product_form_target: 'option', option_id: option_type.id },
          name: option_type.presentation,
          id: "product-option-#{product.id}-#{position}-#{index}",
          disabled: option_disabled %>
    <label
      for='product-option-<%= product.id %>-<%= position %>-<%= index %>'
      class="<%= class_names(
        'text-sm flex items-center justify-between px-4 py-3 transition duration-150',
        {
          'opacity-50 cursor-not-allowed': option_disabled,
          'cursor-pointer hover:bg-accent': !option_disabled,
          'bg-accent/50 font-bold': selected_option == value
        }
      ) %>"
    >
      <span><%= value.presentation %></span>
      <% if selected_option == value %>
        <%= render 'spree/shared/icons/check', size: 16 %>
      <% end %>
    </label>
  <% end %>
<% end %>